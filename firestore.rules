rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function roleFromClaims() {
      return request.auth.token.account_type;
    }

    function isApprover() {
      return isSignedIn() &&
        roleFromClaims() in ["ADMIN", "OC", "WORKSHOP_OFFICER"];
    }

    function changesOnly(keys) {
      return request.resource.data.diff(resource.data).changedKeys().hasOnly(keys);
    }

    function changesStatus() {
      return request.resource.data.diff(resource.data).changedKeys().hasAny(["status"]);
    }

    match /items/{itemId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.status == "pending";
      allow update: if isSignedIn() && (
        (isApprover() &&
          changesOnly(["status"]) &&
          request.resource.data.status in ["active", "rejected"]) ||
        (!changesStatus())
      );
      allow delete: if isApprover();
    }

    match /loads/{loadId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn() && request.resource.data.status == "pending";
      allow update: if isSignedIn() && (
        (isApprover() &&
          changesOnly(["status"]) &&
          request.resource.data.status in ["active", "rejected"]) ||
        (!changesStatus())
      );
      allow delete: if isApprover();
    }

    match /entries/{entryId} {
      allow read, create, update: if isSignedIn();
      allow delete: if false;
    }

    match /demands/{demandId} {
      allow read, create, update, delete: if isSignedIn();
    }

    match /employees/{employeeId} {
      allow read: if isSignedIn();
      allow create, delete: if isApprover();
      allow update: if isApprover() || changesOnly(["last_seen"]);
    }
  }
}
